# ========================================
# BugTracker AI - Environment Variables
# ========================================
# Copy this file to .env and fill in your values

# --- Application ---
VITE_APP_NAME=BugTracker AI
VITE_APP_VERSION=2.0.0
VITE_APP_ENV=development

# --- API Configuration (for future backend) ---
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000

# --- Authentication (JWT) ---
VITE_JWT_SECRET=your-jwt-secret-key-change-in-production
VITE_JWT_EXPIRY=24h
VITE_SESSION_TIMEOUT=86400000

# --- AI Service Configuration ---
VITE_AI_SERVICE_URL=http://localhost:8000
VITE_AI_MODEL_PATH=./models/severity_classifier.pkl
VITE_AI_EMBEDDING_DIM=50
VITE_AI_SIMILARITY_THRESHOLD=0.65

# --- Database (for future backend) ---
# MongoDB
MONGODB_URI=mongodb://localhost:27017/bugtracker
MONGODB_DB_NAME=bugtracker

# PostgreSQL (alternative)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bugtracker
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-in-production

# --- Email Service (for notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@bugtracker.ai

# --- Security ---
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_SALT_ROUNDS=12

# --- Deployment ---
PORT=3000
NODE_ENV=development

GEMINI_API_KEY="AIzaSyCdXjjGJvosg5WqUyXCVgqNW6WZIqDUV3Y"